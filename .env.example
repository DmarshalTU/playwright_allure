# Public demo account (safe to use for this starter):
TEST_USERNAME=tomsmith
TEST_PASSWORD=SuperSecretPassword!

# Used by the API auth smoke test (any non-empty value works with httpbin)
API_KEY=demo-api-key-change-me

# Optional overrides
LOGIN_URL=https://the-internet.herokuapp.com/login
