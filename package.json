{
  "name": "playwright-allure-demo",
  "version": "1.0.0",
  "private": true,
  "description": "User-friendly Playwright + Allure demo with GitHub Actions reports",
  "scripts": {
    "setup": "npm install && npx playwright install --with-deps",
    "setup:ci": "npm ci && npx playwright install --with-deps chromium",
    "test": "playwright test --project=chromium",
    "test:all-browsers": "playwright test",
    "test:smoke": "playwright test --project=chromium --grep @smoke",
    "test:auth": "playwright test --project=chromium --grep @auth",
    "test:login": "playwright test --project=chromium --grep @login",
    "test:regression": "playwright test --project=chromium --grep @regression",
    "test:headed": "playwright test --project=chromium --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --project=chromium --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:file": "playwright test --project=chromium",
    "test:grep": "playwright test --project=chromium --grep",
    "test:green": "playwright test --project=chromium --grep-invert @demo-fail",
    "report": "npm run report:generate && npm run report:open",
    "report:generate": "node scripts/clean.mjs --report-only && allure generate ./allure-results --output ./allure-report",
    "report:open": "allure open ./allure-report",
    "report:serve": "allure generate ./allure-results --output ./allure-report --open",
    "clean": "node scripts/clean.mjs",
    "clean:results": "node scripts/clean.mjs --results-only"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/node": "^22.15.30",
    "allure": "^3.0.0",
    "allure-js-commons": "^3.2.1",
    "allure-playwright": "^3.2.1",
    "dotenv": "^17.4.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
